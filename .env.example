# Telegram alerting (optional — if missing, alerts are skipped gracefully)
TELEGRAM_BOT_TOKEN=your_token
TELEGRAM_CHAT_ID=your_chat_id

# PSI threshold for drift alert
PSI_THRESHOLD=0.20

# ECE threshold for calibration alert
ECE_THRESHOLD=0.05

# Number of initial weeks used as baseline
BASELINE_WEEKS=8
